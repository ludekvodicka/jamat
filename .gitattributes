# Paths excluded from `git archive` exports — e.g. when seeding the public mirror
# from `git archive HEAD | tar -x`. They live in the internal repo but must NOT ship
# in a public release:
#   - .aidocs/      : internal AI-workflow history (plans, research, session summaries)
#   - website brief : internal product/marketing draft, not a repo doc
.aidocs/ export-ignore
docs/jamat-website-brief.md export-ignore

# Normalize line endings so the repo is consistent across Windows/macOS/Linux.
* text=auto
