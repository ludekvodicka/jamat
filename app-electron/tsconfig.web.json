{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "outDir": "./out",
    "rootDir": "..",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@mdext": ["./src/renderer/widgets/mdExtRenderer"],
      "@mdext/*": ["./src/renderer/widgets/mdExtRenderer/*"]
    }
  },
  "include": ["src/renderer/**/*", "src/shared/**/*", "../core/**/*"]
}
